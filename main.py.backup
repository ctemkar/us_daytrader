import os
import asyncio
import logging
from config.settings import SYMBOLS, TICKER_INTERVAL, INVESTMENT_CAP
from data.processor import DataProcessor
from signals.engine import SignalEngine
from llm.client import LLMClient
from execution.orders import OrderManager
from risk.guard import RiskGuard

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(message)s",
    handlers=[logging.FileHandler("trading.log"), logging.StreamHandler()]
)

async def main_loop():
    data_proc = DataProcessor()
    sig_engine = SignalEngine()
    llm = LLMClient()
    executor = OrderManager()
    risk = RiskGuard(investment_cap=INVESTMENT_CAP)

    logging.info("=== ENGINE START: ALPACA US DAY TRADER ===")

    try:
        while True:
            logging.info("Starting sweep for %s symbols", len(SYMBOLS))

            for symbol in SYMBOLS:
                try:
                    logging.info("--- %s ---", symbol)

                    stats = data_proc.get_stats(symbol)
                    if not stats or stats.get("last", 0) <= 0:
                        logging.info("No data for %s", symbol)
                        continue

                    price = float(stats["last"])
                    summary = f"Price:{price} Change:{stats.get('pc',0)}% Vol:{stats.get('vol',0)}"
                    logging.info("Data: %s", summary)

                    try:
                        consensus = await llm.get_consensus(symbol, summary)
                        decision = consensus.get("decision", "HOLD")
                        conf = consensus.get("confidence", 0.0)

                        logging.info("RESULT %s -> %s (conf: %.3f)", symbol, decision, conf)

                        if decision in ["BUY", "SELL"] and conf >= 0.5:
                            if risk.validate(symbol, decision, price):
                                logging.info("EXECUTING ALPACA %s: %s", decision, symbol)
                                res = executor.place_order(symbol, decision, price)
                                logging.info("ORDER SUCCESS: %s", res)
                            else:
                                logging.warning("RISK BLOCKED %s", symbol)
                        elif decision != "HOLD":
                            logging.info("LOW CONFIDENCE: %s (%.3f)", symbol, conf)

                    except Exception as e:
                        logging.error("LLM Error %s: %s", symbol, e)
                        continue

                except Exception as e:
                    logging.error("Loop Error %s: %s", symbol, e)

            logging.info("Sweep complete. Waiting %s seconds...", TICKER_INTERVAL)
            await asyncio.sleep(TICKER_INTERVAL)

    finally:
        await llm.close()

if __name__ == "__main__":
    try:
        asyncio.run(main_loop())
    except KeyboardInterrupt:
        logging.info("Stopped")
